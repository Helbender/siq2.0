{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(uv run ruff check *)",
      "Bash(uv run mypy *)",
      "Bash(playwright-cli open *)",
      "Bash(playwright-cli goto *)",
      "Bash(playwright-cli goto)",
      "Bash(playwright-cli snapshot *)",
      "Bash(playwright-cli snapshot)",
      "Bash(playwright-cli console *)",
      "Bash(playwright-cli console)",
      "Bash(playwright-cli network *)",
      "Bash(playwright-cli network)",
      "Bash(playwright-cli screenshot *)",
      "Bash(playwright-cli screenshot)",
      "Bash(playwright-cli fill *)",
      "Bash(playwright-cli click *)",
      "Bash(playwright-cli tab-list)",
      "Bash(playwright-cli tab-list *)",
      "Bash(playwright-cli close *)",
      "Bash(playwright-cli close)",
      "mcp__stitch__list_screens",
      "mcp__stitch__list_projects",
      "mcp__stitch__get_screen",
      "mcp__stitch__get_project"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "A formatar...",
            "command": "f=$(jq -r '.tool_input.file_path'); rel=\"${f#/home/tiago/Projectos/siq2.0/}\"; case \"$f\" in *.py) case \"$rel\" in api/*) ruff check --fix \"$f\" && ruff format \"$f\" ;; esac ;; *.js|*.jsx) case \"$rel\" in frontend/*) cd /home/tiago/Projectos/siq2.0/frontend && npx prettier --write \"$f\" ;; esac ;; esac 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
